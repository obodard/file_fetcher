# =========================================================
# file_fetcher — environment variable reference
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =========================================================

# ── Database ─────────────────────────────────────
DATABASE_URL=mysql+pymysql://file_fetcher:file_fetcher@localhost:3306/file_fetcher

# ── MariaDB (used by docker-compose) ─────────────
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_USER=file_fetcher
MYSQL_PASSWORD=file_fetcher

# ── SFTP Server ──────────────────────────────────
SFTP_HOST=your.server.com
SFTP_PORT=22
SFTP_USER=your_username
SFTP_PASSWORD=your_password

# Optional: pin the server's host-key fingerprint to prevent MITM attacks.
# Obtain it with:  ssh-keyscan -t ed25519 your.server.com | ssh-keygen -lf -
# Leave empty to skip verification (default).
SFTP_HOST_KEY_FINGERPRINT=

# ── SFTP Scan Paths ──────────────────────────────
SFTP_FILMS_PATH=/media/films
SFTP_SERIES_PATH=/media/series

# ── Local Media Paths ────────────────────────────
LOCAL_FILMS_PATH=/data/local/films
LOCAL_SERIES_PATH=/data/local/series

# ── Scan Control ─────────────────────────────────
# Set to "false" to disable SFTP scanning entirely
SFTP_SCAN_ENABLED=true

# ── Paths ────────────────────────────────────────
FILE_LIST=files_to_download.txt
DOWNLOAD_DIR=./downloads

# ── Intelligent Search (ADK + Gemini) ────────────
GOOGLE_API_KEY=
# Options: gemini-2.5-flash (default, fast), gemini-2.5-pro (complex tasks), gemini-2.5-flash-8b
GEMINI_MODEL=gemini-2.5-flash

OMDB_API_KEY=your_omdb_api_key

# ── Logging ──────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

